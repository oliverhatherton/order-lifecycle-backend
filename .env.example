DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=order_lifecycle
# Set true on the first production deploy to create the schema (no migrations
# yet); leave unset in dev (auto-sync is on when NODE_ENV != production).
# DB_SYNCHRONIZE=true
# Managed Postgres (Neon etc.) needs TLS; Render's internal DB does not.
# DB_SSL=true
NODE_ENV=development
PORT=3000

# CORS + cookies for a browser UI on a DIFFERENT origin than the API.
# CORS_ORIGIN: comma-separated allowed origins (unset = CORS disabled / same-origin only).
# COOKIE_SAMESITE: 'none' to send the refresh cookie cross-site (needs HTTPS), else 'strict'.
# CORS_ORIGIN=https://my-portfolio.example
# COOKIE_SAMESITE=strict

# JWT / auth. Use a long random secret from a secrets manager in real envs.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7

# RabbitMQ (Epic 3). `docker compose up` provides it; management UI at
# http://localhost:15672 (guest/guest). Exchange names are fixed in code.
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Redis cache (Epic 4). `docker compose up` provides it. CACHE_TTL_SECONDS is
# the safety-net TTL behind explicit write invalidation.
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=60

# OpenTelemetry tracing (Epic 5). With no endpoint set, spans print to the
# console. Start the opt-in Jaeger (docker compose --profile observability up)
# and uncomment the endpoint to ship traces; UI at http://localhost:16686.
OTEL_SERVICE_NAME=order-lifecycle-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Used only by `pnpm admin:create` to bootstrap an admin user (never by the app).
# Source these from a secrets manager in real environments, not a committed file.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
